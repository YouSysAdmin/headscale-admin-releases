# Copy to `.env` next to docker-compose.yaml (compose loads it automatically).
# Generate fresh values - do NOT reuse these placeholders:
#   openssl rand -hex 32

# Signs the session cookie (HMAC). Must be >= 32 characters.
HSA_AUTH_SESSION_SECRET=change-me-openssl-rand-hex-32

# Only needed if you enable OIDC in config.docker.yaml.
# HSA_AUTH_OIDC_CLIENT_SECRET=

# First-admin bootstrap (auth enabled). Seeded on first start when no account
# with this email exists yet; idempotent. Password 8-72 chars; omit when OIDC is on.
HSA_AUTH_BOOTSTRAP_ADMIN_EMAIL=you@example.com
HSA_AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me-min-8-chars
