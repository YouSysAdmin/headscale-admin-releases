{{ ansible_managed | comment }}
[Unit]
Description=headscale-admin (admin UI + managed headscale)
# First start downloads the pinned headscale release, so wait for real network.
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User={{ headscale_admin_user }}
Group={{ headscale_admin_group }}
ExecStart={{ headscale_admin_binary_path }} serve --config {{ headscale_admin_config_file }}
WorkingDirectory={{ headscale_admin_home }}

# Secrets / HSA_* overrides. "-" => missing file is not an error.
EnvironmentFile=-{{ headscale_admin_env_file }}

Restart=on-failure
RestartSec=5s

# headscale runs as a child process; control-group kill stops it with the parent.
KillMode=control-group
TimeoutStopSec=30s
{% if headscale_admin_bind_privileged_ports | bool %}

# Allow binding :80/:443 (tls.mode acme / a privileged server.addr) without root.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
{% endif %}

# Hardening. The filesystem is read-only except the paths below: the work_dir
# (config, sqlite DB, keys, socket), the bin_dir (headscale-admin downloads the
# headscale / headscale-pf releases there), and the log directory.
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths={{ headscale_admin_home }} {{ headscale_admin_log_dir }}
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
RestrictNamespaces=true
RestrictRealtime=true
LockPersonality=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallArchitectures=native
SystemCallFilter=@system-service

[Install]
WantedBy=multi-user.target
