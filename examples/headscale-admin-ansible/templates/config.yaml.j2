{{ ansible_managed | comment }}
# headscale-admin config. Secrets (session secret, OIDC client secret) are NOT
# here - they are supplied as HSA_* vars from the env file.
---
server:
  # The single public listener (the "front"): terminates TLS and proxies
  # /admin/* to the UI and everything else to the supervised headscale.
  addr: {{ headscale_admin_server_addr | to_json }}
{% if headscale_admin_db_path | length > 0 %}
  # headscale-admin's own state (bbolt audit log); not headscale's data.
  db_path: {{ headscale_admin_db_path | to_json }}
{% endif %}
{% if headscale_admin_trusted_proxies | length > 0 %}
  trusted_proxies: {{ headscale_admin_trusted_proxies | to_json }}
{% endif %}
{% if headscale_admin_ui_allow_ips | length > 0 %}
  ui_allow_ips: {{ headscale_admin_ui_allow_ips | to_json }}
{% endif %}
{% if headscale_admin_grpc_allow_ips | length > 0 %}
  grpc_allow_ips: {{ headscale_admin_grpc_allow_ips | to_json }}
{% endif %}
{% if headscale_admin_public_signup | bool %}
  # Keep /admin/signup public even when ui_allow_ips is set.
  public_signup: true
{% endif %}
{% if headscale_admin_behind_tls_proxy | bool %}
  # External proxy terminates TLS in front of us: mark cookies Secure + emit HSTS.
  behind_tls_proxy: true
{% endif %}
{% if headscale_admin_root_mode | length > 0 %}
  # What the bare public root "/" serves (redirect | page). Unset -> redirect to signup.
  root:
    mode: {{ headscale_admin_root_mode | to_json }}
{% if headscale_admin_root_target | length > 0 %}
    target: {{ headscale_admin_root_target | to_json }}
{% endif %}
{% if headscale_admin_root_status %}
    status: {{ headscale_admin_root_status | int }}
{% endif %}
{% if headscale_admin_root_body | length > 0 %}
    body: {{ headscale_admin_root_body | to_json }}
{% endif %}
{% if headscale_admin_root_content_type | length > 0 %}
    content_type: {{ headscale_admin_root_content_type | to_json }}
{% endif %}
{% endif %}
  tls:
    # none | manual | self | acme
    mode: {{ headscale_admin_tls_mode | to_json }}
{% if headscale_admin_tls_mode == 'manual' %}
    cert: {{ headscale_admin_tls_cert | to_json }}
    key: {{ headscale_admin_tls_key | to_json }}
{% endif %}
{% if headscale_admin_tls_mode == 'self' %}
{% if headscale_admin_tls_fqdn | length > 0 %}
    fqdn: {{ headscale_admin_tls_fqdn | to_json }}
{% endif %}
{% if headscale_admin_tls_alg | length > 0 %}
    alg: {{ headscale_admin_tls_alg | to_json }}
{% endif %}
{% endif %}
{% if headscale_admin_tls_mode == 'acme' %}
    acme:
      email: {{ headscale_admin_tls_acme_email | to_json }}
      cache_dir: {{ headscale_admin_tls_acme_cache_dir | to_json }}
      http_addr: {{ headscale_admin_tls_acme_http_addr | to_json }}
      hosts: {{ headscale_admin_tls_acme_hosts | to_json }}
{% endif %}

# headscale-admin always supervises headscale itself: it downloads the pinned
# binary, generates/owns headscale.yaml + the sqlite DB / keys under work_dir,
# and dials the unix socket it creates.
headscale:
  request_timeout: {{ headscale_admin_request_timeout | to_json }}
{% if headscale_admin_public_url | length > 0 %}
  public_url: {{ headscale_admin_public_url | to_json }}
{% endif %}
{% if headscale_admin_headscale_version | length > 0 %}
  version: {{ headscale_admin_headscale_version | to_json }}
{% endif %}
  work_dir: {{ headscale_admin_work_dir | to_json }}
  # Downloaded release binaries (headscale, headscale-pf) are cached here.
  bin_dir: {{ headscale_admin_bin_dir | to_json }}
{% if headscale_admin_headscale_binary | length > 0 %}
  binary: {{ headscale_admin_headscale_binary | to_json }}
{% endif %}
  expose_grpc: {{ headscale_admin_expose_grpc | bool | to_json }}
{% if headscale_admin_pf_enabled | bool %}

# External-user sync (headscale-pf). Secrets (source token, LDAP bind password)
# are supplied as HSA_HEADSCALE_PF_* vars from the env file, not here.
headscale_pf:
  enabled: true
{% if headscale_admin_pf_version | length > 0 %}
  version: {{ headscale_admin_pf_version | to_json }}
{% endif %}
{% if headscale_admin_pf_binary | length > 0 %}
  binary: {{ headscale_admin_pf_binary | to_json }}
{% endif %}
  source: {{ headscale_admin_pf_source | to_json }}
{% if headscale_admin_pf_endpoint | length > 0 %}
  endpoint: {{ headscale_admin_pf_endpoint | to_json }}
{% endif %}
{% if headscale_admin_pf_insecure_skip_tls_verify | bool %}
  insecure_skip_tls_verify: true
{% endif %}
{% if headscale_admin_pf_token_file | length > 0 %}
  # Read the source token from a file instead of the env var (mutually exclusive).
  token_file: {{ headscale_admin_pf_token_file | to_json }}
{% endif %}
{% if headscale_admin_pf_source in ['ldap', 'ldaps'] %}
  ldap:
    base_dn: {{ headscale_admin_pf_ldap_base_dn | to_json }}
    bind_dn: {{ headscale_admin_pf_ldap_bind_dn | to_json }}
{% if headscale_admin_pf_ldap_bind_password_file | length > 0 %}
    bind_password_file: {{ headscale_admin_pf_ldap_bind_password_file | to_json }}
{% endif %}
{% if headscale_admin_pf_ldap_default_email_domain | length > 0 %}
    default_email_domain: {{ headscale_admin_pf_ldap_default_email_domain | to_json }}
{% endif %}
{% endif %}
{% if headscale_admin_pf_source in ['kk', 'keycloak'] and headscale_admin_pf_keycloak_realm | length > 0 %}
  keycloak:
    realm: {{ headscale_admin_pf_keycloak_realm | to_json }}
{% endif %}
{% endif %}

auth:
  disabled: {{ headscale_admin_auth_disabled | bool | to_json }}
  session_ttl: {{ headscale_admin_session_ttl | to_json }}
  # session_secret -> env file (HSA_AUTH_SESSION_SECRET). Login is per-user:
  # email+password when OIDC is off, OIDC otherwise. Bootstrap the first admin
  # with `headscale-admin admin create` (or list it in oidc.admin_emails).
  oidc:
    enabled: {{ headscale_admin_oidc_enabled | bool | to_json }}
{% if headscale_admin_oidc_enabled | bool %}
{% if headscale_admin_oidc_label | length > 0 %}
    label: {{ headscale_admin_oidc_label | to_json }}
{% endif %}
    issuer: {{ headscale_admin_oidc_issuer | to_json }}
    client_id: {{ headscale_admin_oidc_client_id | to_json }}
    # client_secret -> env file (HSA_AUTH_OIDC_CLIENT_SECRET)
    redirect_url: {{ headscale_admin_oidc_redirect_url | to_json }}
    scopes: {{ headscale_admin_oidc_scopes | to_json }}
    require_email_verified: {{ headscale_admin_oidc_require_email_verified | bool | to_json }}
{% if headscale_admin_oidc_allowed_domains | length > 0 %}
    allowed_domains: {{ headscale_admin_oidc_allowed_domains | to_json }}
{% endif %}
{% if headscale_admin_oidc_allowed_emails | length > 0 %}
    allowed_emails: {{ headscale_admin_oidc_allowed_emails | to_json }}
{% endif %}
{% if headscale_admin_oidc_groups_claim | length > 0 %}
    groups_claim: {{ headscale_admin_oidc_groups_claim | to_json }}
{% endif %}
{% if headscale_admin_oidc_admin_emails | length > 0 %}
    admin_emails: {{ headscale_admin_oidc_admin_emails | to_json }}
{% endif %}
{% if headscale_admin_oidc_admin_groups | length > 0 %}
    admin_groups: {{ headscale_admin_oidc_admin_groups | to_json }}
{% endif %}
{% if headscale_admin_oidc_operator_groups | length > 0 %}
    operator_groups: {{ headscale_admin_oidc_operator_groups | to_json }}
{% endif %}
{% if headscale_admin_oidc_default_role | length > 0 %}
    default_role: {{ headscale_admin_oidc_default_role | to_json }}
{% endif %}
{% endif %}

logging:
  level: {{ headscale_admin_log_level | to_json }}
  format: {{ headscale_admin_log_format | to_json }}
  color: {{ headscale_admin_log_color | bool | to_json }}
  output: {{ headscale_admin_log_output | to_json }}
