{{ ansible_managed | comment }}
# HSA_*-prefixed overrides for headscale-admin, loaded by systemd
# (EnvironmentFile=). Keep secrets here rather than in config.yaml.
{% if headscale_admin_session_secret | length > 0 %}
HSA_AUTH_SESSION_SECRET={{ headscale_admin_session_secret }}
{% endif %}
{% if headscale_admin_oidc_enabled | bool and headscale_admin_oidc_client_secret | length > 0 %}
HSA_AUTH_OIDC_CLIENT_SECRET={{ headscale_admin_oidc_client_secret }}
{% endif %}
{% if headscale_admin_pf_enabled | bool and headscale_admin_pf_token | length > 0 and headscale_admin_pf_token_file | length == 0 %}
HSA_HEADSCALE_PF_TOKEN={{ headscale_admin_pf_token }}
{% endif %}
{% if headscale_admin_pf_enabled | bool and headscale_admin_pf_ldap_bind_password | length > 0 and headscale_admin_pf_ldap_bind_password_file | length == 0 %}
HSA_HEADSCALE_PF_LDAP_BIND_PASSWORD={{ headscale_admin_pf_ldap_bind_password }}
{% endif %}
{% for key, value in (headscale_admin_extra_env | default({})).items() %}
{{ key }}={{ value }}
{% endfor %}
